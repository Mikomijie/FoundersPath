# Copy this file to backend/.env and fill in your values.
# Never commit backend/.env to git (it's already in .gitignore).

# Groq AI API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Supabase PostgreSQL — Supabase Dashboard → Settings → Database → Transaction pooler URI
# Format: postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-1-region.pooler.supabase.com:6543/postgres
